# DermaMatch backend configuration (all optional).
#
# Lifestyle / side-effect concern detection works out of the box with deterministic
# keyword matching. To make it robust to arbitrary free-text phrasing, provide an
# OpenAI API key below — the backend will then use an LLM to classify which known
# concern categories a patient expressed (it never authors medical claims; all
# patient-facing wording stays curated in code). If the key is absent or the call
# fails, it automatically falls back to keyword matching.

# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_TIMEOUT_SECONDS=8
